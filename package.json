{
  "name": "signaldesk",
  "version": "1.0.0",
  "description": "PM Feedback Intelligence Dashboard on Cloudflare Workers",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 execute signaldesk-db --local --file=schema.sql",
    "db:migrate:remote": "wrangler d1 execute signaldesk-db --remote --file=schema.sql"
  },
  "dependencies": {
    "hono": "^4.12.5"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260305.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
